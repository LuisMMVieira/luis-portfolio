---
import Button from './Button.astro';

interface Props {
  title: string;
  subtitle?: string;
  href?: string;
  cover?: string;
  cta?: string;
  layout?: 'inline' | 'inline-reversed' | 'stacked' | 'no-image-wide';
  status?: string;
}

const {
  title,
  subtitle,
  href,
  cover,
  cta = 'See project',
  layout = 'inline',
  status,
} = Astro.props;
---

<article class:list={['card', `card--${layout}`, { 'card--no-cover': !cover }]}>
  {cover && (
    <div class="card__media">
      <img src={cover} alt={title} loading="lazy" />
    </div>
  )}
  <div class="card__info">
    <div class="card__text">
      <h3 class="card__title">{title}</h3>
      {subtitle && <p class="card__subtitle">{subtitle}</p>}
      {status && <p class="card__status">{status}</p>}
    </div>
    {href && cta && (
      <Button text={cta} variant="primary" href={href} />
    )}
  </div>
</article>
