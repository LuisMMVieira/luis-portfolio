---
interface Props {
  id?: string;
  size?: 'regular' | 'small' | 'big';
}

const { id = 'theme-switch', size = 'regular' } = Astro.props;
const sizeClass = size !== 'regular' ? ` switch--${size}` : '';
---

<label class={`switch${sizeClass}`} for={id}>
  <input class="switch__input" type="checkbox" id={id} checked />
  <span class="switch__track">
    <span class="switch__thumb"></span>
  </span>
</label>

<script>
  document.querySelectorAll('.switch__input').forEach((input) => {
    input.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      // checked = dark (default), unchecked = light
      document.documentElement.dataset.theme = checked ? 'dark' : 'light';
      // Sync all other switches to the same state
      document.querySelectorAll('.switch__input').forEach((other) => {
        if (other !== e.target) {
          (other as HTMLInputElement).checked = checked;
        }
      });
    });
  });
</script>
