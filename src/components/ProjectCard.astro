---
interface Props {
  slug: string;
  title: string;
  cover: string;
  period?: string;
  openable?: boolean;
}

const { slug, title, cover, period, openable = true } = Astro.props;
---

<article class:list={["project-card", !openable && "project-card--no-action"]}>
  {openable ? (
    <a class="project-card-image" href={`/projects/${slug}`} aria-label={title}>
      <img src={cover} alt="" loading="lazy" />
    </a>
  ) : (
    <div class="project-card-image">
      <img src={cover} alt={title} loading="lazy" />
    </div>
  )}
  <div class="project-card-info">
    <h3 class="project-card-title">{title}</h3>
    {!openable && <p class="project-card-status">Coming soon</p>}
  </div>
</article>
