---
interface Props {
  number: string;
  title: string;
  description?: string;
}

const { number, title, description } = Astro.props;
---

<section class="report-section">
  <div class="report-section__header">
    <span class="report-section__number">{number}</span>
    <h2 class="report-section__title">{title}</h2>
  </div>
  {description && (
    <p class="report-section__description">{description}</p>
  )}
  <slot />
</section>
