---
interface Props {
  layout?: 'small' | 'big' | 'canvas' | 'full';
  /** Background color token (e.g. "color-darkest", "bg-elevated", "color-base") — applied to section for full-bleed canvas bg */
  bg?: string;
  /** 2-column layout (Zeplin: 2 col) */
  col2?: boolean;
  /** 3-column layout (Zeplin: 3 col) */
  col3?: boolean;
  /** Media position: full | center-wide | center | left | left-wide | right | right-wide | right-small */
  media?: 'full' | 'center-wide' | 'center' | 'left' | 'left-wide' | 'right' | 'right-wide' | 'right-small';
  /** col2 size ratio: equal (default) | big-small (7:3) | small-big (3:7) */
  col2Sizes?: 'equal' | 'big-small' | 'small-big';
  /** Optional caption displayed below the canvas */
  caption?: string;
}

const { layout = 'big', bg, col2 = false, col3 = false, media, col2Sizes, caption } = Astro.props;

const classes = [
  'post-section',
  `post-section--${layout}`,
  col2 ? 'post-section--col2' : '',
  col3 ? 'post-section--col3' : '',
  media ? `post-section--media-${media}` : '',
  col2Sizes ? `post-section--col2-${col2Sizes}` : ''
].filter(Boolean).join(' ');
---

<section class={classes}>
  <div class="post-canvas" style={bg ? `background-color: var(--${bg})` : undefined}>
    {(col2 || col3) ? (
      <div class="post-section__cols">
        <slot />
      </div>
    ) : (
      <slot />
    )}
  </div>
  {caption && <p class="post-section__caption">{caption}</p>}
</section>
