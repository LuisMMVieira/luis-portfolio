---
/**
 * PostSection — a single sub-section inside a PostSectionGroup.
 *
 * Figma: "Sub Section"
 *   Canvas (css grid)
 *     Content (Place on section grid)  ← auto-generated content-slot
 *       Content/Figure | Content/Text
 *   Caption (optional, outside canvas)
 *
 * When `media` is set, children are auto-wrapped in a `content-slot` div
 * that receives the grid-column placement. For 2-column layouts (media="2-*"),
 * wrap each column's content in its own `<div class="content-slot">` manually.
 *
 * When `scroll` is set, the canvas gets horizontal scroll and the content-slot
 * allows overflow — for panoramic images that are wider than the grid column.
 */
interface Props {
  layout?: 'small' | 'big' | 'canvas' | 'full';
  /** Background color token (e.g. "bg-elevated", "bg-sunken", "color-light") */
  bg?: string;
  /** Media position: full | center-wide | center | left | left-wide | right | right-wide | right-small | 2-left | 2-right | 2-center */
  media?: 'full' | 'center-wide' | 'center' | 'left' | 'left-wide' | 'right' | 'right-wide' | 'right-small' | '2-left' | '2-right' | '2-center';
  /** Canvas padding override (e.g. "spacing-xxl", "spacing-huge") — sets padding-block */
  padding?: string;
  /** Optional caption displayed below the canvas (Figma: Caption at Sub Section level) */
  caption?: string;
  /** Canvas overflow override (e.g. "clip") */
  overflow?: string;
  /** Content-slot gap (e.g. "spacing-xl") — Figma: Content slot gap between children */
  slotGap?: string;
  /** Panoramic scroll — canvas scrolls horizontally, content-slot allows overflow */
  scroll?: boolean;
}

const { layout = 'big', bg, media, padding, caption, overflow, slotGap, scroll = false } = Astro.props;

const is2Col = media?.startsWith('2-');

const classes = [
  'post-subsection',
  `post-subsection--${layout}`,
  media ? `post-subsection--media-${media}` : '',
].filter(Boolean).join(' ');

const canvasClasses = [
  'post-canvas',
  scroll ? 'post-canvas--scroll-x' : '',
].filter(Boolean).join(' ');

const canvasStyle = [
  bg ? `background-color: var(--${bg})` : '',
  padding ? `padding-block: var(--${padding})` : '',
  overflow ? `overflow: ${overflow}` : '',
].filter(Boolean).join('; ') || undefined;

const slotClasses = [
  'content-slot',
  scroll ? 'content-slot--overflow' : '',
].filter(Boolean).join(' ');

const slotStyle = slotGap ? `gap: var(--${slotGap})` : undefined;
---

<section class={classes}>
  <div class={canvasClasses} style={canvasStyle}>
    {is2Col ? (
      <slot />
    ) : media ? (
      <div class={slotClasses} style={slotStyle}>
        <slot />
      </div>
    ) : (
      <slot />
    )}
  </div>
  {caption && <p class="post-subsection__caption">{caption}</p>}
</section>
