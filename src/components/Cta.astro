---
interface Props extends astroHTML.JSX.HTMLAttributes {
  text: string;
  variant?: 'active' | 'passive';
  href?: string;
}

const { text, variant = 'active', href, ...attrs } = Astro.props;
const classes = `cta cta--${variant}`;
const isActive = variant === 'active';
---

{href ? (
  <a class={classes} href={href} {...attrs}>
    {isActive && <span class="cta__bracket">[</span>}
    <span class="cta__label">{text}</span>
    {isActive && <span class="cta__bracket">]</span>}
  </a>
) : (
  <button class={classes} type="button" {...attrs}>
    {isActive && <span class="cta__bracket">[</span>}
    <span class="cta__label">{text}</span>
    {isActive && <span class="cta__bracket">]</span>}
  </button>
)}
