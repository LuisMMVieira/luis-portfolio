---
import BaseLayout from '../../layouts/BaseLayout.astro';
import kanbanData from '../../data/kanban.json';
---

<BaseLayout title="Kanbandamento — Luis Vieira" description="Project kanban board." hideHeader={true}>

  <a href="/andamento" class="cp-home-btn" aria-label="Back to Andamento">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </a>

  <div class="kanban">
    <header class="kanban__header">
      <h1 class="kanban__title">Kanbandamento</h1>
    </header>

    <div class="kanban__board" id="kanban-board">
      <div class="kanban__column" data-column="todo">
        <div class="kanban__column-header">
          <h2 class="kanban__column-title">To Do <span class="kanban__count" data-count="todo">0</span></h2>
        </div>
        <div class="kanban__cards" data-drop="todo"></div>
        <button class="kanban__add-btn" data-add="todo">+ Add card</button>
      </div>

      <div class="kanban__column" data-column="inprogress">
        <div class="kanban__column-header">
          <h2 class="kanban__column-title">In Progress <span class="kanban__count" data-count="inprogress">0</span></h2>
        </div>
        <div class="kanban__cards" data-drop="inprogress"></div>
        <button class="kanban__add-btn" data-add="inprogress">+ Add card</button>
      </div>

      <div class="kanban__column" data-column="onhold">
        <div class="kanban__column-header">
          <h2 class="kanban__column-title">On Hold <span class="kanban__count" data-count="onhold">0</span></h2>
        </div>
        <div class="kanban__cards" data-drop="onhold"></div>
        <button class="kanban__add-btn" data-add="onhold">+ Add card</button>
      </div>

      <div class="kanban__column" data-column="done">
        <div class="kanban__column-header">
          <h2 class="kanban__column-title">Done <span class="kanban__count" data-count="done">0</span></h2>
        </div>
        <div class="kanban__cards" data-drop="done"></div>
        <button class="kanban__add-btn" data-add="done">+ Add card</button>
      </div>
    </div>
  </div>

  <Fragment set:html={`<script>window.__KANBAN_SEED__=${JSON.stringify(kanbanData)};</script>`} />

  <script is:inline>
  // Load board: prefer localStorage, fall back to JSON seed
  var STORAGE_KEY = 'kanban-board';
  if (!localStorage.getItem(STORAGE_KEY) && window.__KANBAN_SEED__) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(window.__KANBAN_SEED__));
  }

  function load() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      if (raw) return JSON.parse(raw);
    } catch(e) {}
    return { todo: [], inprogress: [], onhold: [], done: [] };
  }

  function save(data) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    // Auto-save to disk via dev server API
    fetch('/api/kanban', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    }).catch(function() {}); // silently fail in production (no API)
  }

  function updateCounts(data) {
    for (var col in data) {
      var el = document.querySelector('[data-count="' + col + '"]');
      if (el) el.textContent = String(data[col].length);
    }
  }

  function createCard(text, colId) {
    var card = document.createElement('div');
    card.className = 'kanban__card';
    card.draggable = true;
    card.dataset.column = colId;

    var span = document.createElement('span');
    span.className = 'kanban__card-text';
    span.textContent = text;

    var del = document.createElement('button');
    del.className = 'kanban__card-delete';
    del.textContent = '\u00d7';
    del.setAttribute('aria-label', 'Delete card');
    del.addEventListener('click', function() {
      var data = load();
      var idx = data[colId].indexOf(text);
      if (idx > -1) data[colId].splice(idx, 1);
      save(data);
      card.remove();
      updateCounts(data);
    });

    span.addEventListener('dblclick', function(e) {
      e.stopPropagation();
      card.draggable = false;
      var input = document.createElement('input');
      input.type = 'text';
      input.className = 'kanban__input';
      input.value = text;
      span.replaceWith(input);
      input.focus();
      input.select();

      var done = false;
      function finish(save_edit) {
        if (done) return;
        done = true;
        var newText = input.value.trim();
        if (save_edit && newText && newText !== text) {
          var data = load();
          var idx = data[colId].indexOf(text);
          if (idx > -1) data[colId][idx] = newText;
          save(data);
          renderBoard();
        } else {
          input.replaceWith(span);
          card.draggable = true;
        }
      }

      input.addEventListener('keydown', function(ev) {
        if (ev.key === 'Enter') finish(true);
        if (ev.key === 'Escape') finish(false);
      });
      input.addEventListener('blur', function() { finish(true); });
    });

    card.appendChild(span);
    card.appendChild(del);

    card.addEventListener('dragstart', function(e) {
      card.classList.add('kanban__card--dragging');
      e.dataTransfer.setData('text/plain', JSON.stringify({ text: text, from: colId }));
      e.dataTransfer.effectAllowed = 'move';
    });

    card.addEventListener('dragend', function() {
      card.classList.remove('kanban__card--dragging');
    });

    return card;
  }

  function renderBoard() {
    var data = load();
    for (var colId in data) {
      var container = document.querySelector('[data-drop="' + colId + '"]');
      if (!container) continue;
      container.innerHTML = '';
      for (var i = 0; i < data[colId].length; i++) {
        container.appendChild(createCard(data[colId][i], colId));
      }
    }
    updateCounts(data);
  }

  // Drop zones
  document.querySelectorAll('[data-drop]').forEach(function(zone) {
    var colId = zone.dataset.drop;

    zone.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      zone.classList.add('kanban__cards--dragover');
      var afterEl = getDragAfterElement(zone, e.clientY);
      var dragging = document.querySelector('.kanban__card--dragging');
      if (!dragging) return;
      if (afterEl) {
        zone.insertBefore(dragging, afterEl);
      } else {
        zone.appendChild(dragging);
      }
    });

    zone.addEventListener('dragleave', function(e) {
      if (!zone.contains(e.relatedTarget)) {
        zone.classList.remove('kanban__cards--dragover');
      }
    });

    zone.addEventListener('drop', function(e) {
      e.preventDefault();
      zone.classList.remove('kanban__cards--dragover');
      var raw = e.dataTransfer.getData('text/plain');
      if (!raw) return;
      var parsed = JSON.parse(raw);
      var data = load();

      // Remove from source
      var srcIdx = data[parsed.from].indexOf(parsed.text);
      if (srcIdx > -1) data[parsed.from].splice(srcIdx, 1);

      // Find insert position
      var afterEl = getDragAfterElement(zone, e.clientY);
      var insertIdx = data[colId] ? data[colId].length : 0;
      if (afterEl) {
        var afterText = afterEl.querySelector('.kanban__card-text');
        if (afterText) {
          var pos = data[colId].indexOf(afterText.textContent);
          if (pos >= 0) insertIdx = pos;
        }
      }

      if (!data[colId]) data[colId] = [];
      data[colId].splice(insertIdx, 0, parsed.text);
      save(data);
      renderBoard();
    });
  });

  function getDragAfterElement(container, y) {
    var cards = Array.from(container.querySelectorAll('.kanban__card:not(.kanban__card--dragging)'));
    var closest = { offset: Infinity, element: null };
    for (var i = 0; i < cards.length; i++) {
      var box = cards[i].getBoundingClientRect();
      var offset = y - box.top - box.height / 2;
      if (offset < 0 && -offset < closest.offset) {
        closest = { offset: -offset, element: cards[i] };
      }
    }
    return closest.element;
  }

  // Add card buttons
  document.querySelectorAll('[data-add]').forEach(function(btn) {
    var colId = btn.dataset.add;

    btn.addEventListener('click', function() {
      if (btn.previousElementSibling && btn.previousElementSibling.classList.contains('kanban__input-wrap')) return;

      var wrap = document.createElement('div');
      wrap.className = 'kanban__input-wrap';

      var input = document.createElement('input');
      input.type = 'text';
      input.className = 'kanban__input';
      input.placeholder = 'Card title...';

      var cancel = function() { wrap.remove(); };

      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && input.value.trim()) {
          var data = load();
          if (!data[colId]) data[colId] = [];
          data[colId].push(input.value.trim());
          save(data);
          renderBoard();
          wrap.remove();
        }
        if (e.key === 'Escape') cancel();
      });

      input.addEventListener('blur', function() {
        setTimeout(function() {
          if (document.body.contains(wrap) && !input.value.trim()) cancel();
        }, 150);
      });

      wrap.appendChild(input);
      btn.parentElement.insertBefore(wrap, btn);
      input.focus();
    });
  });

  // Initial render
  renderBoard();
  </script>

</BaseLayout>
