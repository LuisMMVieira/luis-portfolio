---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';

import IntroContent from '../content/intro.md';
import BeliefsContent from '../content/beliefs.md';
import BackgroundContent from '../content/background.md';
import AboutContent from '../content/about.md';

// Get all projects, sorted by order
const projects = (await getCollection('projects'))
  .filter((project) => !project.data.draft && project.slug !== 'namecheapvpn')
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout>
  <Section id="intro">
    <IntroContent />
  </Section>

  <Section id="work">
    <div class="projects-list">
      {
        projects.map((project) => (
          <Card
            title={project.data.title}
            cover={project.data.cover}
            href={`/projects/${project.slug}`}
            layout="inline"
            cta="See project"
          />
        ))
      }
    </div>
  </Section>

  {/* <Section id="beliefs">
    <BeliefsContent />
  </Section> */}

  <Section id="background">
    <BackgroundContent />
  </Section>

  <Section id="about" bg="--color-emphasis">
    <AboutContent />
    <div class="about-contact">
      <div class="about-contact__group">
        <span class="about-contact__label">Contact:</span>
        <span class="about-contact__email-wrap">
          <a
            href="#"
            class="about-contact__link about-contact__link--dotted about-contact__copy-email"
            data-email="hello@luisvieira.design">hello@luisvieira.design</a>
          <span class="about-contact__tooltip" aria-live="polite">Copied</span>
        </span>
      </div>
      <div class="about-contact__group">
        <span class="about-contact__label">Social:</span>
        <div class="about-contact__social-links">
          <a
            href="https://x.com/Luis_M_Vieira"
            class="about-contact__link"
            target="_blank"
            rel="noopener noreferrer">X/Twitter</a>
          <a
            href="https://www.linkedin.com/in/lmmvieira/"
            class="about-contact__link"
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
