---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionIndex from '../../components/CollectionIndex.astro';
import { getCollection } from 'astro:content';

const reports = (await getCollection('reports'))
  .filter((r) => r.slug !== 'report-template' && !r.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Reports — Luis Vieira" description="All reports." hideHeader={true}>
  <CollectionIndex title="Reports" basePath="reports" items={reports} />
</BaseLayout>
