---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReportHeader from "../../components/mdx/report/ReportHeader.astro";
import ReportSection from "../../components/mdx/report/ReportSection.astro";
import KpiGrid from "../../components/mdx/report/KpiGrid.astro";
import KpiCard from "../../components/mdx/report/KpiCard.astro";
import ChartCard from "../../components/mdx/report/ChartCard.astro";
import DataTable from "../../components/mdx/report/DataTable.astro";
import Callout from "../../components/mdx/report/Callout.astro";
import BackButton from "../../components/BackButton.astro";
import Annotation from "../../components/mdx/report/Annotation.astro";
import Figure from "../../components/mdx/Figure.astro";
import Divider from "../../components/Divider.astro";

export async function getStaticPaths() {
  const reports = await getCollection("reports");
  return reports.map((report) => ({
    params: { slug: report.slug },
    props: { report },
  }));
}

interface Props {
  report: CollectionEntry<"reports">;
}

const { report } = Astro.props as Props;
const { Content } = await report.render();
const isDraft = report.data.draft;
---

<BaseLayout title={`${report.data.title} — Luis Vieira`} hideHeader={true} theme={report.data.theme}>
  <script slot="head" is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  {isDraft && <BackButton />}
  <div class="report-page">
    <ReportHeader
      title={report.data.title}
      subtitle={report.data.subtitle}
      date={report.data.date}
    />
    <div class="report-body">
      <Content components={{
        ReportSection, KpiGrid, KpiCard, ChartCard,
        DataTable, Callout, Annotation, Figure, Divider
      }} />
    </div>
  </div>
  <script is:inline src="/scripts/chart-init.js"></script>
</BaseLayout>
