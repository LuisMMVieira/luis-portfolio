---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackButton from '../components/BackButton.astro';
import Button from '../components/Button.astro';
import Switch from '../components/Switch.astro';
import Divider from '../components/Divider.astro';
import Card from '../components/Card.astro';
import PostHeader from '../components/mdx/PostHeader.astro';
import PostSection from '../components/mdx/PostSection.astro';
import PostText from '../components/mdx/PostText.astro';
import Figure from '../components/mdx/Figure.astro';
import Phone from '../components/mdx/Phone.astro';
---

<BaseLayout title="Components — Luis Vieira" description="Private design system reference page." hideHeader={true}>

  {/* Floating index button */}
  <BackButton />

  <div class="components-page">

    {/* ── Header ──────────────────────────────── */}

    <header class="cp-page-header">
      <h1 class="cp-page-header__title">Components</h1>
      <p class="cp-page-header__subtitle">Design system reference. All components with agnostic placeholder content.</p>
    </header>

    {/* ── Dock Navigation (bottom) ────────────── */}

    <nav class="cp-docknav" aria-label="Components navigation">
      <div class="cp-docknav__bar">
        <span class="cp-docknav__indicator">Grid</span>
        <Switch id="docknav-theme-switch" />
      </div>
      <div class="cp-docknav__panel">
        <div class="cp-docknav__group">
          <span class="cp-docknav__label">Foundations</span>
          <div class="cp-docknav__links">
            <a href="#grid" class="cp-docknav__link" data-spy-target="grid">Grid</a>
            <a href="#typography" class="cp-docknav__link" data-spy-target="typography">Typography</a>
            <a href="#colors" class="cp-docknav__link" data-spy-target="colors">Colors</a>
            <a href="#lines" class="cp-docknav__link" data-spy-target="lines">Lines</a>
            <a href="#motion" class="cp-docknav__link" data-spy-target="motion">Motion</a>
          </div>
        </div>
        <div class="cp-docknav__group">
          <span class="cp-docknav__label">Elements</span>
          <div class="cp-docknav__links">
            <a href="#button" class="cp-docknav__link" data-spy-target="button">Button</a>
            <a href="#link" class="cp-docknav__link" data-spy-target="link">Link</a>
            <a href="#switch" class="cp-docknav__link" data-spy-target="switch">Switch</a>
            <a href="#selector" class="cp-docknav__link" data-spy-target="selector">Selector</a>
            <a href="#divider" class="cp-docknav__link" data-spy-target="divider">Divider</a>
          </div>
        </div>
        <div class="cp-docknav__group">
          <span class="cp-docknav__label">Compositions</span>
          <div class="cp-docknav__links">
            <a href="#post-header" class="cp-docknav__link" data-spy-target="post-header">PostHeader</a>
            <a href="#post-text" class="cp-docknav__link" data-spy-target="post-text">PostText</a>
            <a href="#post-meta" class="cp-docknav__link" data-spy-target="post-meta">PostMeta</a>
            <a href="#figure" class="cp-docknav__link" data-spy-target="figure">Figure</a>
            <a href="#phone" class="cp-docknav__link" data-spy-target="phone">Phone</a>
            <a href="#layouts" class="cp-docknav__link" data-spy-target="layouts">Layouts</a>
            <a href="#card" class="cp-docknav__link" data-spy-target="card">Card</a>
          </div>
        </div>
      </div>
    </nav>

    {/* ── Content ─────────────────────────────── */}

    <div class="cp-layout">
      <div class="cp-content">

        {/* ═══════════════════════════════════════
            FOUNDATIONS
            ═══════════════════════════════════════ */}

        {/* ── Grid ────────────────────────────── */}

        <section id="grid" class="section cp-grid-showcase">
          <div class="cp-grid-col"><span>1</span></div>
          <div class="cp-grid-col"><span>2</span></div>
          <div class="cp-grid-col"><span>3</span></div>
          <div class="cp-grid-col"><span>4</span></div>
          <div class="cp-grid-col"><span>5</span></div>
          <div class="cp-grid-col"><span>6</span></div>
          <div class="cp-grid-col"><span>7</span></div>
          <div class="cp-grid-col"><span>8</span></div>
          <div class="cp-grid-col"><span>9</span></div>
          <div class="cp-grid-col"><span>10</span></div>
          <div class="cp-grid-col"><span>11</span></div>
          <div class="cp-grid-col"><span>12</span></div>
        </section>

        <Divider label="Typography" description="Dazzed SemiBold for titles, IBM Plex Sans for body text." spaceAbove="xl" spaceBelow="none" />

        {/* ── Typography ──────────────────────── */}

        <div id="typography">
          <section class="cp-section">
            <div class="cp-card">
              <div class="cp-card__preview" style="display: flex; flex-direction: column; gap: var(--spacing-sm); padding: var(--spacing-lg);">
                <div class="cp-type-row">
                  <span class="cp-type-token">--type-title-xl</span>
                  <p class="cp-type-xl">Title Extra Large</p>
                </div>
                <div class="cp-type-row">
                  <span class="cp-type-token">--type-title-l</span>
                  <p class="cp-type-l">Title Large</p>
                </div>
                <div class="cp-type-row">
                  <span class="cp-type-token">--type-title-m</span>
                  <p class="cp-type-m">Title Medium</p>
                </div>
                <div class="cp-type-row">
                  <span class="cp-type-token">--type-title-s</span>
                  <p class="cp-type-s">Title Small</p>
                </div>
                <div class="cp-type-row">
                  <span class="cp-type-token">--type-title-xs</span>
                  <p class="cp-type-xs">Title Extra Small</p>
                </div>
                <div style="margin-top: var(--spacing-md); display: flex; flex-direction: column; gap: var(--spacing-xxs);">
                  <span class="cp-type-token">--type-text-m</span>
                  <p>Paragraph text uses IBM Plex Sans at 14px with 185% line-height. This is the default body copy style—secondary color, regular weight.</p>
                  <p><strong>Bold text renders in semibold weight with primary color.</strong> This demonstrates the inline emphasis treatment.</p>
                </div>
              </div>
            </div>
          </section>
        </div>

        <Divider label="Colors" description="Base color palette. All values in oklab. Toggle theme in the dock bar to compare." spaceAbove="xl" spaceBelow="none" />

        {/* ── Colors ──────────────────────────── */}

        <div id="colors">
          <section class="cp-section">

            <div class="cp-color-columns">

              {/* Column 1 — Base */}
              <div class="card cp-color-column">
                <span class="cp-color-column__label">Base colors</span>
                <div class="cp-swatch cp-swatch--color-lightest">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-lightest</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use cp-swatch__use--light">--bg-elevated</span>
                    </div>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-superpastel-light">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-superpastel-light</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use">--text-primary</span>
                      <span class="cp-swatch__use cp-swatch__use--light">--bg-default</span>
                      <span class="cp-swatch__use cp-swatch__use--light">--bg-lens</span>
                    </div>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-light">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-light</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use cp-swatch__use--light">--bg-sunken</span>
                      <span class="cp-swatch__use cp-swatch__use--light">--border-shy</span>
                    </div>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-medium-light">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-medium-light</span>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-base">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-base</span>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-medium-dark">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-medium-dark</span>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-dark">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-dark</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use">--bg-elevated</span>
                      <span class="cp-swatch__use">--border-shy</span>
                    </div>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-superpastel-dark">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-superpastel-dark</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use">--bg-default</span>
                      <span class="cp-swatch__use">--bg-lens</span>
                      <span class="cp-swatch__use cp-swatch__use--light">--text-primary</span>
                    </div>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-darkest">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-darkest</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use">--bg-sunken</span>
                    </div>
                  </div>
                </div>
              </div>

              {/* Column 2 — Opacity */}
              <div class="card cp-color-column">
                <span class="cp-color-column__label">Opacity colors</span>
                <div class="cp-swatch cp-swatch--color-white-opacity-high">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-white-opacity-high</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use">--text-secondary</span>
                    </div>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-white-opacity-mid">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-white-opacity-mid</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use">--text-shy</span>
                      <span class="cp-swatch__use">--border-strong</span>
                      <span class="cp-swatch__use">--button-secondary-hover</span>
                    </div>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-white-opacity-low">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-white-opacity-low</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use">--border-default</span>
                      <span class="cp-swatch__use">--button-secondary-idle</span>
                    </div>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-black-opacity-high">
                    <div class="cp-swatch__preview"></div>
                    <div class="cp-swatch__info">
                      <span class="cp-swatch__label">--color-black-opacity-high</span>
                      <div class="cp-swatch__uses">
                        <span class="cp-swatch__use cp-swatch__use--light">--text-secondary</span>
                      </div>
                    </div>
                  </div>
                  <div class="cp-swatch cp-swatch--color-black-opacity-mid">
                    <div class="cp-swatch__preview"></div>
                    <div class="cp-swatch__info">
                      <span class="cp-swatch__label">--color-black-opacity-mid</span>
                      <div class="cp-swatch__uses">
                        <span class="cp-swatch__use cp-swatch__use--light">--text-shy</span>
                        <span class="cp-swatch__use cp-swatch__use--light">--border-strong</span>
                        <span class="cp-swatch__use cp-swatch__use--light">--button-secondary-hover</span>
                      </div>
                    </div>
                  </div>
                <div class="cp-swatch cp-swatch--color-black-opacity-low">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-black-opacity-low</span>
                    <div class="cp-swatch__uses">
                      <span class="cp-swatch__use cp-swatch__use--light">--border-default</span>
                      <span class="cp-swatch__use cp-swatch__use--light">--button-secondary-idle</span>
                    </div>
                  </div>
                </div>
              </div>

              {/* Column 3 — Emphasis */}
              <div class="card cp-color-column">
                <span class="cp-color-column__label">Emphasis color</span>
                <div class="cp-swatch cp-swatch--color-emphasis">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-emphasis</span>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-emphasis-opacity-high">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-emphasis-opacity-high</span>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-emphasis-opacity-mid">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-emphasis-opacity-mid</span>
                  </div>
                </div>
                <div class="cp-swatch cp-swatch--color-emphasis-opacity-low">
                  <div class="cp-swatch__preview"></div>
                  <div class="cp-swatch__info">
                    <span class="cp-swatch__label">--color-emphasis-opacity-low</span>
                  </div>
                </div>
              </div>

            </div>

            {/* Lens demo */}
            <div class="cp-lens-demo" id="lens-demo">
              <img src="https://picsum.photos/1200/400" alt="" class="cp-lens-demo__photo" />
              <div class="cp-lens-demo__overlay"></div>
              <div class="cp-lens-demo__handle">
                <div class="cp-lens-demo__handle-line"></div>
                <div class="cp-lens-demo__handle-grip"></div>
                <div class="cp-lens-demo__handle-line"></div>
              </div>
              <span class="cp-lens-demo__label">--bg-lens</span>
            </div>
          </section>
        </div>

        <Divider label="Lines" description="Width × color matrix. Every combination rendered at actual size against contrasting backgrounds." spaceAbove="xl" spaceBelow="none" />

        {/* ── Lines ───────────────────────────── */}

        <div id="lines">
          <section class="cp-section">
            <div class="cp-card" data-playground id="lines-playground">
              <div class="cp-card__controls">
                <div class="cp-control-group">
                  <span class="cp-control-label">width</span>
                  <div class="cp-pills" data-control="line-width">
                    <button class="cp-pill" data-value="line-width">line-width <span class="cp-type-token">0.5px</span></button>
                    <button class="cp-pill is-active" data-value="border-width-default">border-width-default <span class="cp-type-token">1px</span></button>
                    <button class="cp-pill" data-value="line-width-thick">line-width-thick <span class="cp-type-token">1.5px</span></button>
                  </div>
                </div>
                <div class="cp-control-divider"></div>
                <div class="cp-control-group">
                  <span class="cp-control-label">color</span>
                  <div class="cp-pills" data-control="line-color">
                    <button class="cp-pill" data-value="border-shy">shy</button>
                    <button class="cp-pill is-active" data-value="border-default">default</button>
                    <button class="cp-pill" data-value="border-strong">strong</button>
                  </div>
                </div>
              </div>
              <div class="cp-card__preview" style="display: block; padding: 0; min-height: auto;">
                {/* Line on dark bg */}
                <div class="cp-line-strip cp-line-strip--dark">
                  <span class="cp-line-strip__label">dark bg</span>
                  <div class="cp-line-sample" id="line-sample-dark"></div>
                </div>
              </div>
            </div>

            {/* Full matrix reference */}
            <div class="cp-card" style="margin-top: var(--spacing-md);">
              <div class="cp-card__preview" style="display: block; padding: var(--spacing-lg);">
                <div class="cp-line-matrix">
                  {/* Column headers */}
                  <div class="cp-line-matrix__header"></div>
                  <div class="cp-line-matrix__header">--border-shy</div>
                  <div class="cp-line-matrix__header">--border-default</div>
                  <div class="cp-line-matrix__header">--border-strong</div>

                  {/* Row 1: line-width (0.5px) */}
                  <div class="cp-line-matrix__label">--line-width <span class="cp-type-token">0.5px</span></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--line-width); background: var(--border-shy);"></div></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--line-width); background: var(--border-default);"></div></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--line-width); background: var(--border-strong);"></div></div>

                  {/* Row 2: border-width-default (1px) */}
                  <div class="cp-line-matrix__label">--border-width-default <span class="cp-type-token">1px</span></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--border-width-default); background: var(--border-shy);"></div></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--border-width-default); background: var(--border-default);"></div></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--border-width-default); background: var(--border-strong);"></div></div>

                  {/* Row 3: line-width-thick (1.5px) */}
                  <div class="cp-line-matrix__label">--line-width-thick <span class="cp-type-token">1.5px</span></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--line-width-thick); background: var(--border-shy);"></div></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--line-width-thick); background: var(--border-default);"></div></div>
                  <div class="cp-line-matrix__cell"><div class="cp-line-matrix__sample" style="height: var(--line-width-thick); background: var(--border-strong);"></div></div>
                </div>
              </div>
            </div>
          </section>
        </div>

        <Divider label="Motion" description="Scroll reveal, fade transitions, durations, and easing curves." spaceAbove="xl" spaceBelow="none" />

        {/* ── Motion ──────────────────────────── */}

        <div id="motion">
          <section class="cp-section">

            {/* Tokens reference */}
            <div class="cp-card" style="margin-bottom: var(--spacing-lg);">
              <div class="cp-card__preview" style="display: block; padding: var(--spacing-md); gap: var(--spacing-lg); flex-direction: column;">
                <div style="display: flex; gap: var(--spacing-xl); flex-wrap: wrap;">
                  <div>
                    <p class="cp-type-xs" style="color: var(--text-shy); margin-bottom: var(--spacing-xs);">Durations</p>
                    <dl class="cp-motion-tokens">
                      <div><dt>instant</dt><dd>0.1s</dd></div>
                      <div><dt>fast</dt><dd>0.2s</dd></div>
                      <div><dt>moderate</dt><dd>0.4s</dd></div>
                      <div><dt>slow</dt><dd>0.65s</dd></div>
                      <div><dt>deliberate</dt><dd>1s</dd></div>
                    </dl>
                  </div>
                  <div>
                    <p class="cp-type-xs" style="color: var(--text-shy); margin-bottom: var(--spacing-xs);">Easings</p>
                    <dl class="cp-motion-tokens">
                      <div><dt>linear</dt><dd>(.25,.25,.75,.75)</dd></div>
                      <div><dt>soft</dt><dd>(.25,.25,.35,1)</dd></div>
                      <div><dt>ease-out</dt><dd>(0,0,.2,1)</dd></div>
                      <div><dt>ease-in</dt><dd>(.4,0,1,1)</dd></div>
                      <div><dt>ease-in-out</dt><dd>(.4,0,.2,1)</dd></div>
                      <div><dt>bounce</dt><dd>(.34,1.56,.64,1)</dd></div>
                    </dl>
                  </div>
                  <div>
                    <p class="cp-type-xs" style="color: var(--text-shy); margin-bottom: var(--spacing-xs);">Distances</p>
                    <dl class="cp-motion-tokens">
                      <div><dt>subtle</dt><dd>20px</dd></div>
                      <div><dt>default</dt><dd>80px</dd></div>
                      <div><dt>dramatic</dt><dd>160px</dd></div>
                    </dl>
                  </div>
                </div>
              </div>
            </div>

            {/* Interactive playground */}
            <div class="cp-card" data-motion-playground>
              <div class="cp-card__controls">
                <div class="cp-control-group">
                  <span class="cp-control-label">type</span>
                  <div class="cp-pills" data-control="motion-type">
                    <button class="cp-pill is-active" data-value="reveal">reveal</button>
                    <button class="cp-pill" data-value="fade-in">fade-in</button>
                  </div>
                </div>
                <div class="cp-control-divider"></div>
                <div class="cp-control-group">
                  <span class="cp-control-label">speed</span>
                  <div class="cp-pills" data-control="motion-speed">
                    <button class="cp-pill" data-value="instant">instant</button>
                    <button class="cp-pill" data-value="fast">fast</button>
                    <button class="cp-pill" data-value="moderate">moderate</button>
                    <button class="cp-pill is-active" data-value="slow">slow</button>
                    <button class="cp-pill" data-value="deliberate">deliberate</button>
                  </div>
                </div>
                <div class="cp-control-divider"></div>
                <div class="cp-control-group">
                  <span class="cp-control-label">easing</span>
                  <div class="cp-pills" data-control="motion-easing">
                    <button class="cp-pill" data-value="linear">linear</button>
                    <button class="cp-pill is-active" data-value="soft">soft</button>
                    <button class="cp-pill" data-value="ease-out">ease-out</button>
                    <button class="cp-pill" data-value="ease-in">ease-in</button>
                    <button class="cp-pill" data-value="ease-in-out">ease-in-out</button>
                    <button class="cp-pill" data-value="bounce">bounce</button>
                  </div>
                </div>
                <div class="cp-control-divider"></div>
                <div class="cp-control-group" data-show-when="motion-type:reveal">
                  <span class="cp-control-label">distance</span>
                  <div class="cp-pills" data-control="motion-distance">
                    <button class="cp-pill" data-value="subtle">subtle</button>
                    <button class="cp-pill is-active" data-value="default">default</button>
                    <button class="cp-pill" data-value="dramatic">dramatic</button>
                  </div>
                </div>
                <div class="cp-control-divider"></div>
                <div class="cp-control-group">
                  <button class="btn btn--primary btn--sm" data-replay>Replay</button>
                </div>
              </div>
              <div class="cp-card__preview cp-motion-preview">
