  {/* ── Layout Playground Script ─────────────── */}

  <script is:inline>
  (function () {
    var lp = document.querySelector('[data-playground="layout-playground"]');
    if (!lp) return;

    var LOREM = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.';

    function val(name) {
      var g = lp.querySelector('[data-control="' + name + '"]');
      if (!g) return null;
      var a = g.querySelector('.is-active');
      return a ? a.getAttribute('data-value') : null;
    }

    function itemHTML(type, ratio) {
      if (type === 'figure') {
        return '<figure class="post-figure"><div class="cp-layout-item" style="aspect-ratio:' + ratio + ';"></div></figure>';
      }
      if (type === 'figure-caption') {
        return '<figure class="post-figure"><div class="cp-layout-item" style="aspect-ratio:' + ratio + ';"></div><figcaption class="post-figure__caption">Optional caption text</figcaption></figure>';
      }
      return '<div class="post-text"><p>' + LOREM + '</p></div>';
    }

    function render() {
      var bp = val('breakpoint') || 'xl';
      var caption = val('caption') || 'off';
      var items = val('items') || '1';
      var position = val('position') || 'full';
      var item1 = val('item1') || 'figure';
      var item2 = val('item2') || 'figure';

      // Breakpoint frame
      var frame = lp.querySelector('[data-bp-frame]');
      var label = lp.querySelector('[data-bp-label]');
      if (frame) {
        frame.classList.remove('cp-bp-frame--xs', 'cp-bp-frame--md', 'cp-bp-frame--xl');
        frame.classList.add('cp-bp-frame--' + bp);
      }
      if (label) {
        label.textContent = ({ xs: '375px', md: '768px', xl: '1200px' })[bp] || '';
      }

      // Conditional control visibility
      lp.querySelectorAll('[data-show-when]').forEach(function (el) {
        var parts = el.getAttribute('data-show-when').split(':');
        el.style.display = val(parts[0]) === parts[1] ? '' : 'none';
      });

      // Section classes
      var cls = ['post-subsection', 'post-subsection--canvas'];
      if (items === '1') cls.push('post-subsection--media-' + position);
      if (items === '2') cls.push('post-subsection--col2');

      // Inner content
      var inner;
      if (items === '2') {
        inner = '<div class="post-subsection__cols">' + itemHTML(item1, '4/3') + itemHTML(item2, '4/3') + '</div>';
      } else {
        inner = itemHTML(item1, '3/2');
      }

      // Canvas + optional section caption
      var html = '<section class="' + cls.join(' ') + '">'
        + '<div class="post-canvas">' + inner + '</div>'
        + (caption === 'on' ? '<p class="post-subsection__caption">Section caption text</p>' : '')
        + '</section>';

      var preview = lp.querySelector('[data-layout-preview]');
      if (preview) preview.innerHTML = html;
    }

    render();

    lp.addEventListener('click', function (e) {
      var pill = e.target.closest('.cp-pill');
      if (!pill) return;
      e.stopPropagation();
      var group = pill.closest('.cp-pills');
      group.querySelectorAll('.cp-pill').forEach(function (p) { p.classList.remove('is-active'); });
      pill.classList.add('is-active');
      render();
    });
  })();
  </script>

  {/* ── Playground Script ─────────────────────── */}

  <script is:inline>
  (function () {
    document.addEventListener('click', function (e) {
      var pill = e.target.closest('.cp-pill');
      if (!pill) return;

      var playground = pill.closest('[data-playground]');
      if (!playground) return;

      // Update active pill in this control group
      var group = pill.closest('.cp-pills');
      group.querySelectorAll('.cp-pill').forEach(function (p) {
        p.classList.remove('is-active');
      });
      pill.classList.add('is-active');

      // Collect all active values from this playground (pills + toggles)
      var controls = {};
      playground.querySelectorAll('.cp-pills').forEach(function (g) {
        var controlName = g.getAttribute('data-control');
        var activePill = g.querySelector('.is-active');
        if (controlName && activePill) {
          controls[controlName] = activePill.getAttribute('data-value');
        }
      });
      playground.querySelectorAll('.cp-toggle').forEach(function (t) {
        var controlName = t.getAttribute('data-control');
        if (controlName) {
          controls[controlName] = t.classList.contains('is-active')
            ? t.getAttribute('data-value-on')
            : t.getAttribute('data-value-off');
        }
      });

      // --- Show/hide logic ---
      var variants = playground.querySelectorAll('[data-variant-key]');
      if (variants.length > 0) {
        variants.forEach(function (el) {
          var key = el.getAttribute('data-variant-key');
          var pairs = key.split('|');
          var match = pairs.every(function (pair) {
            var parts = pair.split(':');
            var name = parts[0];
            var value = parts[1];
            return !controls[name] || controls[name] === value;
          });
          el.hidden = !match;
        });
      }

      // --- Class-swap logic ---
      var targets = playground.querySelectorAll('[data-class-target]:not([hidden])');
      playground.querySelectorAll('[data-variant-key]:not([hidden]) [data-class-target]').forEach(function (t) {
        targets = Array.from(new Set([].concat(Array.from(targets), [t])));
      });

      targets.forEach(function (target) {
        var configStr = target.getAttribute('data-class-config');
        if (!configStr) return;
        var config = JSON.parse(configStr);

        Object.keys(config).forEach(function (controlName) {
          var activeValue = controls[controlName];
          if (!activeValue) return;
          var entry = config[controlName];

          if (typeof entry === 'string') {
            var prefix = entry;
            var classList = Array.from(target.classList);
            classList.forEach(function (cls) {
              if (cls.indexOf(prefix) === 0) {
                target.classList.remove(cls);
              }
            });
            target.classList.add(prefix + activeValue);
          } else if (entry && entry.p && entry.v) {
            entry.v.forEach(function (v) {
              target.classList.remove(entry.p + v);
            });
            target.classList.add(entry.p + activeValue);
          }
        });
      });

      // --- State simulation for buttons ---
      if (controls.state) {
        var btns = playground.querySelectorAll('.btn');
        btns.forEach(function (btn) {
          btn.classList.toggle('is-hovered', controls.state === 'hover');
          btn.classList.toggle('is-disabled', controls.state === 'disabled');
          btn.disabled = controls.state === 'disabled';
        });
      }

      // --- Size toggle for buttons ---
      if (controls.size) {
        playground.querySelectorAll('[data-size-target]').forEach(function (btn) {
          btn.classList.toggle('btn--sm', controls.size === 'sm');
        });
      }

      // --- Breakpoint frame width ---
      if (controls.breakpoint) {
        var frame = playground.querySelector('[data-bp-frame]');
        var label = playground.querySelector('[data-bp-label]');
        if (frame) {
          frame.classList.remove('cp-bp-frame--xs', 'cp-bp-frame--md', 'cp-bp-frame--xl');
          frame.classList.add('cp-bp-frame--' + controls.breakpoint);
        }
        if (label) {
          var widths = { xs: '375px', md: '768px', xl: '1200px' };
          label.textContent = widths[controls.breakpoint] || '';
        }
      }
    });

    /* ── Toggle (boolean switch) handler ── */
    document.addEventListener('click', function (e) {
      var toggle = e.target.closest('.cp-toggle');
      if (!toggle) return;

      var playground = toggle.closest('[data-playground]');
      if (!playground) return;

      // Flip state
      toggle.classList.toggle('is-active');

      // Collect all controls (pills + toggles) from this playground
      var controls = {};
      playground.querySelectorAll('.cp-pills').forEach(function (g) {
        var controlName = g.getAttribute('data-control');
        var activePill = g.querySelector('.is-active');
        if (controlName && activePill) {
          controls[controlName] = activePill.getAttribute('data-value');
        }
      });
      playground.querySelectorAll('.cp-toggle').forEach(function (t) {
        var controlName = t.getAttribute('data-control');
        if (controlName) {
          controls[controlName] = t.classList.contains('is-active')
            ? t.getAttribute('data-value-on')
            : t.getAttribute('data-value-off');
        }
      });

      // Show/hide variant matching
      var variants = playground.querySelectorAll('[data-variant-key]');
      if (variants.length > 0) {
        variants.forEach(function (el) {
          var key = el.getAttribute('data-variant-key');
          var pairs = key.split('|');
          var match = pairs.every(function (pair) {
            var parts = pair.split(':');
            var name = parts[0];
            var value = parts[1];
            return !controls[name] || controls[name] === value;
          });
          el.hidden = !match;
        });
      }
    });
  })();
  </script>

  {/* ── Phone playground: bg toggle + size slider ── */}
  <script is:inline>
  (function () {
    var pg = document.getElementById('phone-playground');
    if (!pg) return;
    var preview = document.getElementById('phone-preview');
    var slider = document.getElementById('phone-size-slider');
    var label = document.getElementById('phone-size-label');

    // Background toggle — handled via the general pill click system,
    // but we need to react to the 'bg' control value
    function applyBg() {
      var bgPill = pg.querySelector('[data-control="bg"] .is-active');
      if (bgPill) {
        var val = bgPill.getAttribute('data-value');
        var bgMap = { light: 'var(--color-light)', grey: 'var(--color-medium-dark)', dark: '' };
        preview.style.backgroundColor = bgMap[val] || '';
      }
    }
    var observer = new MutationObserver(applyBg);
    observer.observe(pg, { subtree: true, attributes: true, attributeFilter: ['class'] });
    applyBg(); // Apply initial state on load

    // Size slider — sets --phone-w on all phone instances
    function applySize(v) {
      label.textContent = v;
      pg.querySelectorAll('.phone').forEach(function (phone) {
        phone.style.setProperty('--phone-w', v);
      });
    }
    if (slider && label) {
      // Apply initial value on load
      applySize(slider.value);
      slider.addEventListener('input', function () {
        applySize(slider.value);
      });
    }
  })();
  </script>

  {/* ── Lines playground: width × color ─────────── */}
  <script is:inline>
  (function () {
    var pg = document.getElementById('lines-playground');
    if (!pg) return;
    var sampleDark = document.getElementById('line-sample-dark');

    function applyLine() {
      var widthPill = pg.querySelector('[data-control="line-width"] .is-active');
      var colorPill = pg.querySelector('[data-control="line-color"] .is-active');
      if (!widthPill || !colorPill) return;
      var w = 'var(--' + widthPill.getAttribute('data-value') + ')';
      var c = 'var(--' + colorPill.getAttribute('data-value') + ')';
      sampleDark.style.height = w;
      sampleDark.style.backgroundColor = c;
    }

    var observer = new MutationObserver(applyLine);
    observer.observe(pg, { subtree: true, attributes: true, attributeFilter: ['class'] });
    applyLine(); // Apply initial state on load
  })();
  </script>

  {/* ── Card playground: subtitle toggle ───────── */}
  <script is:inline>
  (function () {
    var preview = document.getElementById('card-preview');
    if (!preview) return;
    var pg = preview.closest('[data-playground]');
    if (!pg) return;

    function applySubtitle() {
      var subtitleToggle = pg.querySelector('.cp-toggle[data-control="subtitle"]');
      if (subtitleToggle) {
        var show = subtitleToggle.classList.contains('is-active');
        preview.querySelectorAll('.card__subtitle').forEach(function (el) {
          el.style.display = show ? '' : 'none';
        });
      }
    }
    var observer = new MutationObserver(applySubtitle);
    observer.observe(pg, { subtree: true, attributes: true, attributeFilter: ['class'] });
    applySubtitle(); // Apply initial state on load
  })();
  </script>

  {/* ── Scroll Spy + Dock Nav Script ──────────── */}

  <script is:inline>
  (function () {
    var sections = document.querySelectorAll('.cp-content > [id]');
    var links = document.querySelectorAll('.cp-docknav__link');
    var indicator = document.querySelector('.cp-docknav__indicator');
    var docknav = document.querySelector('.cp-docknav');

    if (!sections.length || !links.length) return;

    var currentId = sections[0] ? sections[0].id : '';

    function updateSpy() {
      var scrollY = window.scrollY + window.innerHeight * 0.2;
      var found = '';
      sections.forEach(function (section) {
        if (section.offsetTop <= scrollY) found = section.id;
      });
      if (found && found !== currentId) {
        currentId = found;
        links.forEach(function (link) { link.classList.remove('is-active'); });
        var activeLink = document.querySelector(
          '.cp-docknav__link[data-spy-target="' + found + '"]'
        );
        if (activeLink) {
          activeLink.classList.add('is-active');
          if (indicator) indicator.textContent = activeLink.textContent;
        }
      }
    }

    window.addEventListener('scroll', updateSpy, { passive: true });
    updateSpy();

    if (links.length > 0 && !document.querySelector('.cp-docknav__link.is-active')) {
      links[0].classList.add('is-active');
    }

    // Smooth scroll on link click + collapse panel
    if (docknav) {
      docknav.addEventListener('click', function (e) {
        var link = e.target.closest('.cp-docknav__link');
        if (!link) return;
        e.preventDefault();
        var targetId = link.getAttribute('data-spy-target');
        var target = document.getElementById(targetId);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', '#' + targetId);
          docknav.classList.add('is-collapsed');
          setTimeout(function () { docknav.classList.remove('is-collapsed'); }, 600);
        }
      });
    }
  })();
  </script>

  {/* ── Selector demo pills (interactive) ── */}
  <script is:inline>
  (function () {
    var sp = document.getElementById('selector-playground');
    if (!sp) return;
    // Make demo pills in the preview toggle among siblings
    sp.querySelector('.cp-card__preview').addEventListener('click', function (e) {
      var pill = e.target.closest('.cp-pill');
      if (!pill) return;
      var group = pill.closest('.cp-pills');
      if (!group || group.closest('.cp-card__controls')) return; // skip control pills
      group.querySelectorAll('.cp-pill').forEach(function (p) { p.classList.remove('is-active'); });
      pill.classList.add('is-active');
    });
  })();
  </script>

  {/* ── Motion playground ──────────────── */}
  <script is:inline>
  (function () {
    var pg = document.querySelector('[data-motion-playground]');
    if (!pg) return;

    var target = pg.querySelector('[data-motion-target]');
    var replayBtn = pg.querySelector('[data-replay]');

    var type = 'reveal';
    var speed = 'slow';
    var easing = 'soft';
    var distance = 'default';

    function getState() {
      pg.querySelectorAll('[data-control]').forEach(function (group) {
        var name = group.getAttribute('data-control');
        var active = group.querySelector('.is-active');
        if (!active) return;
        var val = active.getAttribute('data-value');
        if (name === 'motion-type') type = val;
        if (name === 'motion-speed') speed = val;
        if (name === 'motion-easing') easing = val;
        if (name === 'motion-distance') distance = val;
      });
    }

    function play() {
      getState();

      // Kill transitions, reset to hidden state
      target.style.transition = 'none';
      target.className = 'cp-motion-box';
      target.classList.add(type);
      target.classList.add('motion--' + speed);
      target.classList.add('motion--' + easing);
      if (type === 'reveal') {
        target.classList.add('motion--' + distance);
      }
      void target.offsetHeight;

      // Re-enable transitions and trigger
      target.style.transition = '';
      requestAnimationFrame(function () {
        target.classList.add('is-visible');
      });
    }

    // Replay button
    replayBtn.addEventListener('click', play);

    // Toggle active pill + re-play on any pill change
    pg.querySelectorAll('.cp-pill:not([data-replay])').forEach(function (pill) {
      pill.addEventListener('click', function () {
        var group = pill.closest('.cp-pills');
        group.querySelectorAll('.cp-pill').forEach(function (p) { p.classList.remove('is-active'); });
        pill.classList.add('is-active');
        setTimeout(play, 50);
      });
    });

    // Show/hide distance control based on type
    var distGroup = pg.querySelector('[data-show-when="motion-type:reveal"]');
    pg.querySelector('[data-control="motion-type"]').addEventListener('click', function (e) {
      var pill = e.target.closest('.cp-pill');
      if (!pill) return;
      distGroup.hidden = pill.getAttribute('data-value') !== 'reveal';
    });

    // Initial play
    play();
  })();
  </script>

  {/* ── Lens demo drag ─────────── */}
  <script is:inline>
  (function () {
    var demo = document.getElementById('lens-demo');
    if (!demo) return;
    var overlay = demo.querySelector('.cp-lens-demo__overlay');
    var handle = demo.querySelector('.cp-lens-demo__handle');
    var dragging = false;

    function setPosition(x) {
      var rect = demo.getBoundingClientRect();
      var pct = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
      overlay.style.width = pct + '%';
      handle.style.left = pct + '%';
    }

    function onMove(e) {
      if (!dragging) return;
      e.preventDefault();
      var x = e.touches ? e.touches[0].clientX : e.clientX;
      setPosition(x);
    }

    function onUp() {
      dragging = false;
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
      document.removeEventListener('touchmove', onMove);
      document.removeEventListener('touchend', onUp);
    }

    handle.addEventListener('mousedown', function (e) {
      e.preventDefault();
      dragging = true;
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });

    handle.addEventListener('touchstart', function (e) {
      dragging = true;
      document.addEventListener('touchmove', onMove, { passive: false });
      document.addEventListener('touchend', onUp);
    });
  })();
  </script>

