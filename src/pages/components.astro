---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Cta from '../components/Cta.astro';
import Switch from '../components/Switch.astro';
import Divider from '../components/Divider.astro';
import Card from '../components/Card.astro';
import PostHeader from '../components/mdx/PostHeader.astro';
import PostSection from '../components/mdx/PostSection.astro';
import PostText from '../components/mdx/PostText.astro';
import Figure from '../components/mdx/Figure.astro';
import Phone from '../components/mdx/Phone.astro';
---

<BaseLayout title="Components — Luis Vieira" description="Private design system reference page." hideHeader={true}>

  {/* Floating index button */}
  <a href="/andamento" class="cp-home-btn" aria-label="Back to index">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="7" rx="1"></rect>
      <rect x="3" y="14" width="7" height="7" rx="1"></rect>
      <line x1="14" y1="4" x2="21" y2="4"></line>
      <line x1="14" y1="8" x2="21" y2="8"></line>
      <line x1="14" y1="15" x2="21" y2="15"></line>
      <line x1="14" y1="19" x2="21" y2="19"></line>
    </svg>
  </a>

  <div class="components-page">

    {/* ── Header ──────────────────────────────── */}

    <header class="cp-page-header">
      <h1 class="cp-page-header__title">Components</h1>
      <p class="cp-page-header__subtitle">Design system reference. All components with agnostic placeholder content.</p>
    </header>

    {/* ── Dock Navigation (bottom) ────────────── */}

    <nav class="cp-docknav" aria-label="Components navigation">
      <div class="cp-docknav__bar">
        <span class="cp-docknav__indicator">Grid</span>
      </div>
      <div class="cp-docknav__panel">
        <div class="cp-docknav__group">
          <span class="cp-docknav__label">Foundations</span>
          <div class="cp-docknav__links">
            <a href="#grid" class="cp-docknav__link" data-spy-target="grid">Grid</a>
            <a href="#typography" class="cp-docknav__link" data-spy-target="typography">Typography</a>
            <a href="#colors" class="cp-docknav__link" data-spy-target="colors">Colors</a>
          </div>
        </div>
        <div class="cp-docknav__group">
          <span class="cp-docknav__label">Primitives</span>
          <div class="cp-docknav__links">
            <a href="#button-cta" class="cp-docknav__link" data-spy-target="button-cta">Button & CTA</a>
            <a href="#switch-divider" class="cp-docknav__link" data-spy-target="switch-divider">Switch & Divider</a>
            <a href="#lines" class="cp-docknav__link" data-spy-target="lines">Lines</a>
            <a href="#motion" class="cp-docknav__link" data-spy-target="motion">Motion</a>
          </div>
        </div>
        <div class="cp-docknav__group">
          <span class="cp-docknav__label">Components</span>
          <div class="cp-docknav__links">
            <a href="#post-header" class="cp-docknav__link" data-spy-target="post-header">PostHeader</a>
            <a href="#post-text-meta" class="cp-docknav__link" data-spy-target="post-text-meta">PostText & PostMeta</a>
            <a href="#figure" class="cp-docknav__link" data-spy-target="figure">Figure</a>
            <a href="#phone" class="cp-docknav__link" data-spy-target="phone">Phone</a>
            <a href="#post-subsection-layouts" class="cp-docknav__link" data-spy-target="post-subsection-layouts">Layouts</a>
            <a href="#card" class="cp-docknav__link" data-spy-target="card">Card</a>
            <a href="#additional" class="cp-docknav__link" data-spy-target="additional">Additional</a>
          </div>
        </div>
      </div>
    </nav>

    {/* ── Content ─────────────────────────────── */}

    <div class="cp-layout">
      <div class="cp-content">

        {/* ── Grid Showcase ───────────────────── */}

        <section id="grid" class="section cp-grid-showcase">
          <div class="cp-grid-col"><span>1</span></div>
          <div class="cp-grid-col"><span>2</span></div>
          <div class="cp-grid-col"><span>3</span></div>
          <div class="cp-grid-col"><span>4</span></div>
          <div class="cp-grid-col"><span>5</span></div>
          <div class="cp-grid-col"><span>6</span></div>
          <div class="cp-grid-col"><span>7</span></div>
          <div class="cp-grid-col"><span>8</span></div>
          <div class="cp-grid-col"><span>9</span></div>
          <div class="cp-grid-col"><span>10</span></div>
          <div class="cp-grid-col"><span>11</span></div>
          <div class="cp-grid-col"><span>12</span></div>
        </section>

        {/* ── Typography ──────────────────────── */}

        <div id="typography">
          <section class="cp-section">
            <div class="cp-header">
              <h2 class="cp-header__title">Typography</h2>
              <p class="cp-header__desc">Title sizes (Dazzed SemiBold) and body text (IBM Plex Sans Regular).</p>
            </div>
            <div style="display: flex; flex-direction: column; gap: var(--spacing-sm);">
              <p class="cp-type-xl">Title Extra Large</p>
              <p class="cp-type-l">Title Large</p>
              <p class="cp-type-m">Title Medium</p>
              <p class="cp-type-s">Title Small</p>
              <p class="cp-type-xs">Title Extra Small</p>
              <div style="display: flex; flex-direction: column; gap: var(--spacing-xxs); margin-top: var(--spacing-md);">
                <p>Paragraph text uses IBM Plex Sans at 14px with 185% line-height. This is the default body copy style — secondary color, regular weight.</p>
                <p><strong>Bold text renders in semibold weight with primary color.</strong> This demonstrates the inline emphasis treatment.</p>
              </div>
            </div>
          </section>
        </div>

        {/* ── Colors ──────────────────────────── */}

        <div id="colors">
          <section class="cp-section">
            <div class="cp-header">
              <h2 class="cp-header__title">Colors</h2>
              <p class="cp-header__desc">Semantic color tokens. All values use oklab color space.</p>
            </div>
            <div class="cp-swatches">
              <div class="cp-swatch cp-swatch--bg-default">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--bg-default</span>
              </div>
              <div class="cp-swatch cp-swatch--bg-elevated">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--bg-elevated</span>
              </div>
              <div class="cp-swatch cp-swatch--text-primary">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--text-primary</span>
              </div>
              <div class="cp-swatch cp-swatch--text-secondary">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--text-secondary</span>
              </div>
              <div class="cp-swatch cp-swatch--text-shy">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--text-shy</span>
              </div>
              <div class="cp-swatch cp-swatch--border-default">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--border-default</span>
              </div>
              <div class="cp-swatch cp-swatch--border-strong">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--border-strong</span>
              </div>
              <div class="cp-swatch cp-swatch--color-emphasis">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--color-emphasis</span>
              </div>
              <div class="cp-swatch cp-swatch--button-primary-idle">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--button-primary-idle</span>
              </div>
              <div class="cp-swatch cp-swatch--button-secondary-idle">
                <div class="cp-swatch__preview"></div>
                <span class="cp-swatch__label">--button-secondary-idle</span>
              </div>
            </div>
          </section>
        </div>

        {/* ── Button + CTA (two-column) ──────── */}

        <div id="button-cta">
          <section class="cp-section">
            <div class="cp-header">
              <h2 class="cp-header__title">Button & CTA</h2>
              <p class="cp-header__desc">Primary interactive elements. Pill-shaped buttons and inline calls-to-action.</p>
            </div>
            <div class="cp-cols">
            <div class="cp-card" data-playground>
              <div class="cp-card__controls">
                <div class="cp-control-group">
                  <span class="cp-control-label">variant</span>
                  <div class="cp-pills" data-control="variant">
                    <button class="cp-pill is-active" data-value="primary">primary</button>
                    <button class="cp-pill" data-value="secondary">secondary</button>
                  </div>
                </div>
                <div class="cp-control-group">
                  <span class="cp-control-label">state</span>
                  <div class="cp-pills" data-control="state">
                    <button class="cp-pill is-active" data-value="idle">idle</button>
                    <button class="cp-pill" data-value="hover">hover</button>
                  </div>
                </div>
                <div class="cp-control-group">
                  <span class="cp-control-label">element</span>
                  <div class="cp-pills" data-control="element">
                    <button class="cp-pill is-active" data-value="button">button</button>
                    <button class="cp-pill" data-value="link">link</button>
                  </div>
                </div>
              </div>
              <div class="cp-card__preview">
                <div data-variant-key="element:button">
                  <button class="btn btn--primary" data-class-target data-class-config='{"variant":"btn--"}'>Button Label</button>
                </div>
                <div data-variant-key="element:link" hidden>
                  <a href="#" class="btn btn--primary" data-class-target data-class-config='{"variant":"btn--"}'>Link Label</a>
                </div>
              </div>
            </div>
            <div class="cp-card">
              <div class="cp-card__preview" style="flex-direction: column; gap: var(--spacing-lg); align-items: flex-start;">
                <Cta text="Active CTA" variant="active" />
                <Cta text="Passive CTA" variant="passive" />
              </div>
            </div>
            </div>
          </section>
        </div>

        {/* ── Switch + Divider (two-column) ──── */}

        <div id="switch-divider">
          <section class="cp-section">
            <div class="cp-header">
              <h2 class="cp-header__title">Switch & Divider</h2>
              <p class="cp-header__desc">Toggle control and section separator.</p>
            </div>
            <div class="cp-cols">
              <div class="cp-card">
                <div class="cp-card__preview">
                  <div class="cp-inline-demo">
                    <span class="cp-inline-demo__label">Theme toggle</span>
                    <Switch id="demo-switch" />
                  </div>
                </div>
              </div>
              <div class="cp-card" data-playground>
                <div class="cp-card__controls">
                  <div class="cp-control-group">
                    <span class="cp-control-label">label</span>
                    <div class="cp-pills" data-control="label">
                      <button class="cp-pill is-active" data-value="with">with label</button>
                      <button class="cp-pill" data-value="none">none</button>
                    </div>
                  </div>
                </div>
                <div class="cp-card__preview" style="display: block; padding: var(--spacing-lg);">
                  <div data-variant-key="label:with">
                    <Divider label="Section Title" spaceAbove="none" spaceBelow="none" />
                  </div>
                  <div data-variant-key="label:none" hidden>
                    <Divider spaceAbove="none" spaceBelow="none" />
                  </div>
                </div>
              </div>
            </div>
          </section>
        </div>

        {/* ── Lines ─────────────────────────────── */}

        <div id="lines">
          <section class="cp-section">
            <div class="cp-header">
              <h2 class="cp-header__title">Lines</h2>
              <p class="cp-header__desc">Border width and color tokens. All lines use <code>background-color</code> for rendering.</p>
            </div>
            <div class="cp-card" data-playground id="lines-playground">
              <div class="cp-card__controls">
                <div class="cp-control-group">
                  <span class="cp-control-label">bg</span>
                  <div class="cp-pills" data-control="bg">
                    <button class="cp-pill is-active" data-value="dark">dark</button>
                    <button class="cp-pill" data-value="light">light</button>
                  </div>
                </div>
              </div>
              <div class="cp-card__preview" id="lines-preview" style="display: flex; flex-direction: column; gap: var(--spacing-xl); padding: var(--spacing-lg); transition: background-color var(--duration-moderate) var(--ease-soft);">

                {/* Width tokens */}
                <div>
                  <p class="cp-type-xs" style="color: var(--text-shy); margin-bottom: var(--spacing-sm);">Widths</p>
                  <div style="display: flex; flex-direction: column; gap: var(--spacing-md);">
                    <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                      <span class="cp-control-label" style="min-width: 10em;">--line-width</span>
                      <div style="flex: 1; height: var(--line-width); background: var(--border-default);"></div>
                      <span class="cp-type-xs" style="color: var(--text-shy); min-width: 3em; text-align: right;">0.5px</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                      <span class="cp-control-label" style="min-width: 10em;">--border-width-default</span>
                      <div style="flex: 1; height: var(--border-width-default); background: var(--border-default);"></div>
                      <span class="cp-type-xs" style="color: var(--text-shy); min-width: 3em; text-align: right;">1px</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                      <span class="cp-control-label" style="min-width: 10em;">--line-width-thick</span>
                      <div style="flex: 1; height: var(--line-width-thick); background: var(--border-default);"></div>
                      <span class="cp-type-xs" style="color: var(--text-shy); min-width: 3em; text-align: right;">1.5px</span>
                    </div>
                  </div>
                </div>

                {/* Color tokens */}
                <div>
                  <p class="cp-type-xs" style="color: var(--text-shy); margin-bottom: var(--spacing-sm);">Colors</p>
                  <div style="display: flex; flex-direction: column; gap: var(--spacing-md);">
                    <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                      <span class="cp-control-label" style="min-width: 10em;">--border-shy</span>
                      <div style="flex: 1; height: var(--border-width-default); background: var(--border-shy);"></div>
                    </div>
                    <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                      <span class="cp-control-label" style="min-width: 10em;">--border-default</span>
                      <div style="flex: 1; height: var(--border-width-default); background: var(--border-default);"></div>
                    </div>
                    <div style="display: flex; align-items: center; gap: var(--spacing-md);">
                      <span class="cp-control-label" style="min-width: 10em;">--border-strong</span>
                      <div style="flex: 1; height: var(--border-width-default); background: var(--border-strong);"></div>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </section>
        </div>

        {/* ── Motion ────────────────────────────── */}

        <div id="motion">
          <section class="cp-section">
            <div class="cp-header">
              <h2 class="cp-header__title">Motion</h2>
              <p class="cp-header__desc">Scroll reveal, fade transitions, durations, and easing curves.</p>
            </div>

            {/* Tokens reference */}
            <div class="cp-card" style="margin-bottom: var(--spacing-lg);">
              <div class="cp-card__preview" style="display: block; padding: var(--spacing-md); gap: var(--spacing-lg); flex-direction: column;">
                <div style="display: flex; gap: var(--spacing-xl); flex-wrap: wrap;">
                  <div>
                    <p class="cp-type-xs" style="color: var(--text-shy); margin-bottom: var(--spacing-xs);">Durations</p>
                    <dl class="cp-motion-tokens">
                      <div><dt>instant</dt><dd>0.1s</dd></div>
                      <div><dt>fast</dt><dd>0.2s</dd></div>
                      <div><dt>moderate</dt><dd>0.4s</dd></div>
                      <div><dt>slow</dt><dd>0.65s</dd></div>
                      <div><dt>deliberate</dt><dd>1s</dd></div>
                    </dl>
                  </div>
                  <div>
                    <p class="cp-type-xs" style="color: var(--text-shy); margin-bottom: var(--spacing-xs);">Easings</p>
                    <dl class="cp-motion-tokens">
                      <div><dt>linear</dt><dd>(.25,.25,.75,.75)</dd></div>
                      <div><dt>soft</dt><dd>(.25,.25,.35,1)</dd></div>
                      <div><dt>ease-out</dt><dd>(0,0,.2,1)</dd></div>
                      <div><dt>ease-in</dt><dd>(.4,0,1,1)</dd></div>
                      <div><dt>ease-in-out</dt><dd>(.4,0,.2,1)</dd></div>
                      <div><dt>bounce</dt><dd>(.34,1.56,.64,1)</dd></div>
                    </dl>
                  </div>
                  <div>
                    <p class="cp-type-xs" style="color: var(--text-shy); margin-bottom: var(--spacing-xs);">Distances</p>
                    <dl class="cp-motion-tokens">
                      <div><dt>subtle</dt><dd>20px</dd></div>
                      <div><dt>default</dt><dd>80px</dd></div>
                      <div><dt>dramatic</dt><dd>160px</dd></div>
                    </dl>
                  </div>
                </div>
              </div>
            </div>

            {/* Interactive playground */}
            <div class="cp-card" data-motion-playground>
              <div class="cp-card__controls">
                <div class="cp-control-group">
                  <span class="cp-control-label">type</span>
                  <div class="cp-pills" data-control="motion-type">
                    <button class="cp-pill is-active" data-value="reveal">reveal</button>
                    <button class="cp-pill" data-value="fade-in">fade-in</button>
                  </div>
                </div>
                <div class="cp-control-group">
                  <span class="cp-control-label">speed</span>
                  <div class="cp-pills" data-control="motion-speed">
                    <button class="cp-pill" data-value="instant">instant</button>
                    <button class="cp-pill" data-value="fast">fast</button>
                    <button class="cp-pill" data-value="moderate">moderate</button>
                    <button class="cp-pill is-active" data-value="slow">slow</button>
                    <button class="cp-pill" data-value="deliberate">deliberate</button>
                  </div>
                </div>
                <div class="cp-control-group">
                  <span class="cp-control-label">easing</span>
                  <div class="cp-pills" data-control="motion-easing">
                    <button class="cp-pill" data-value="linear">linear</button>
                    <button class="cp-pill is-active" data-value="soft">soft</button>
                    <button class="cp-pill" data-value="ease-out">ease-out</button>
                    <button class="cp-pill" data-value="ease-in">ease-in</button>
                    <button class="cp-pill" data-value="ease-in-out">ease-in-out</button>
                    <button class="cp-pill" data-value="bounce">bounce</button>
                  </div>
                </div>
                <div class="cp-control-group" data-show-when="motion-type:reveal">
                  <span class="cp-control-label">distance</span>
                  <div class="cp-pills" data-control="motion-distance">
                    <button class="cp-pill" data-value="subtle">subtle</button>
                    <button class="cp-pill is-active" data-value="default">default</button>
                    <button class="cp-pill" data-value="dramatic">dramatic</button>
                  </div>
                </div>
                <div class="cp-control-group">
                  <span class="cp-control-label">&nbsp;</span>
                  <button class="cp-pill cp-pill--action" data-replay>Replay</button>
                </div>
              </div>
              <div class="cp-card__preview cp-motion-preview">
                <div class="cp-motion-box" data-motion-target></div>
              </div>
            </div>
          </section>
        </div>

        {/* ── PostHeader ──────────────────────── */}

        <div id="post-header">
          <section class="cp-section">
            <div class="cp-header">
              <h2 class="cp-header__title">PostHeader</h2>
              <p class="cp-header__desc">Title group with optional subtitle and intro paragraph.</p>
            </div>
            <div class="cp-card" data-playground>
              <div class="cp-card__controls">
                <div class="cp-control-group">
                  <span class="cp-control-label">subtitle</span>
                  <div class="cp-pills" data-control="subtitle">
                    <button class="cp-pill is-active" data-value="with">with</button>
                    <button class="cp-pill" data-value="without">without</button>
                  </div>
                </div>
                <div class="cp-control-group">
                  <span class="cp-control-label">intro</span>
                  <div class="cp-pills" data-control="intro">
                    <button class="cp-pill is-active" data-value="with">with</button>
                    <button class="cp-pill" data-value="without">without</button>
                  </div>
                </div>
              </div>
              <div class="cp-card__preview cp-card__preview--flush">
                <div class="post-page cp-post-context" data-variant-key="subtitle:with|intro:with">
                  <PostHeader title="Post title" subtitle="Post Subtitle">
                    <p>The intro paragraph lives in the default slot. It supports rich content and multiple paragraphs of introductory text for a project post.</p>
                  </PostHeader>
                </div>
                <div class="post-page cp-post-context" data-variant-key="subtitle:with|intro:without" hidden>
                  <PostHeader title="Post title" subtitle="Post Subtitle" />
                </div>
                <div class="post-page cp-post-context" data-variant-key="subtitle:without|intro:with" hidden>
                  <PostHeader title="Post title">
                    <p>The intro paragraph lives in the default slot. It supports rich content and multiple paragraphs of introductory text for a project post.</p>
                  </PostHeader>
                </div>
                <div class="post-page cp-post-context" data-variant-key="subtitle:without|intro:without" hidden>
                  <PostHeader title="Post title" />
                </div>
              </div>
            </div>
          </section>
        </div>

        {/* ── PostText + PostMeta (two-column) ── */}

        <div id="post-text-meta">
          <section class="cp-section">
            <div class="cp-header">
              <h2 class="cp-header__title">PostText & PostMeta</h2>
              <p class="cp-header__desc">Content heading with paragraph, and key-value metadata grid.</p>
            </div>
            <div class="cp-cols">
              <div class="cp-card">
                <div class="cp-card__preview cp-card__preview--flush">
                  <div class="post-page cp-post-context">
                    <PostSection layout="big">
                      <PostText heading="Section Title">
                        <p>Paragraph text below the section title. This demonstrates how running text pairs with headings inside the narrow reading column.</p>
                      </PostText>
                    </PostSection>
                  </div>
                </div>
              </div>
              <div class="cp-card">
                <div class="cp-card__preview cp-card__preview--flush">
                  <div class="post-page cp-post-context">
                    <PostSection layout="big">
                      <dl class="post-meta">
                        <div class="post-meta__row">
                          <dt class="post-meta__label">Role</dt>
                          <dd class="post-meta__value">Value placeholder</dd>
                        </div>
                        <div class="post-meta__row">
                          <dt class="post-meta__label">Focus</dt>
                          <dd class="post-meta__value">Value placeholder</dd>
                        </div>
                        <div class="post-meta__row">
                          <dt class="post-meta__label">Team</dt>
                          <dd class="post-meta__value">Value placeholder</dd>
                        </div>
                        <div class="post-meta__row">
                          <dt class="post-meta__label">Period</dt>
                          <dd class="post-meta__value">Value placeholder</dd>
                        </div>
                      </dl>
