---
import { getCollection, type CollectionEntry } from "astro:content";
import "../../styles/main.scss";
import PostSection from "../../components/mdx/PostSection.astro";
import PostSectionGroup from "../../components/mdx/PostSectionGroup.astro";
import PostHeader from "../../components/mdx/PostHeader.astro";
import PostText from "../../components/mdx/PostText.astro";
import Figure from "../../components/mdx/Figure.astro";
import ImageCarousel from "../../components/mdx/ImageCarousel.astro";
import Video from "../../components/mdx/Video.astro";
import Phone from "../../components/mdx/Phone.astro";
import Divider from "../../components/Divider.astro";
import Card from "../../components/Card.astro";
import PasswordGate from "../../components/PasswordGate.astro";
import AgentationToolbar from "../../components/AgentationToolbar";

const isDev = import.meta.env.DEV;

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props as Props;
const { Content } = await project.render();
const isTemplate = project.slug === 'project-template';
const theme = project.data.theme ?? 'dark';
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="preload"
      href="/fonts/Dazzed-SemiBold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{project.data.title} — Luis Vieira</title>
    <meta name="description" content={project.data.subtitle || project.data.title} />
    <script is:inline>
      document.documentElement.classList.add(
        document.documentElement.dataset.theme || 'dark'
      );
    </script>
  </head>
  <body>
    {project.data.nda && <PasswordGate />}
    <div class="project-page">
      <button class="project-page__close" aria-label="Close" data-close>
        <svg width="24" height="24" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <path d="M15 1L1 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
      <div class="project-page__container">
        <div class:list={["post-page", { "post-page--draft": isTemplate }]}>
          <Content components={{ PostSection, PostSectionGroup, PostHeader, PostText, Figure, ImageCarousel, Video, Phone, Divider, Card }} />
        </div>
      </div>
    </div>

    <script is:inline>
      function goBack() {
        if (window.history.length > 1) {
          history.back();
        } else {
          window.location.href = '/';
        }
      }

      document.querySelector('[data-close]')?.addEventListener('click', goBack);

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') goBack();
      });
    </script>

    {/* Drag-to-scroll for panoramic images */}
    <script is:inline>
    (function () {
      document.querySelectorAll('[data-drag-scroll]').forEach(function (el) {
        var startX, scrollStart, isDragging = false;

        el.addEventListener('mousedown', function (e) {
          isDragging = true;
          startX = e.clientX;
          scrollStart = el.scrollLeft;
          el.classList.add('is-dragging');
          e.preventDefault();
        });

        window.addEventListener('mousemove', function (e) {
          if (!isDragging) return;
          el.scrollLeft = scrollStart - (e.clientX - startX);
        });

        window.addEventListener('mouseup', function () {
          if (!isDragging) return;
          isDragging = false;
          el.classList.remove('is-dragging');
        });
      });
    })();
    </script>
    <script type="module" src="/scripts/main.js"></script>
    {isDev && <AgentationToolbar client:only="react" />}
  </body>
</html>
