---
import { getCollection, type CollectionEntry } from "astro:content";
import "../../styles/main.scss";
import PostSection from "../../components/mdx/PostSection.astro";
import PostSectionGroup from "../../components/mdx/PostSectionGroup.astro";
import PostHeader from "../../components/mdx/PostHeader.astro";
import PostText from "../../components/mdx/PostText.astro";
import Figure from "../../components/mdx/Figure.astro";
import ImageCarousel from "../../components/mdx/ImageCarousel.astro";
import Video from "../../components/mdx/Video.astro";
import Divider from "../../components/Divider.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props as Props;
const { Content } = await project.render();
const isTemplate = project.slug === 'project-template';
const theme = project.data.theme ?? 'dark';
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="preload"
      href="/fonts/DazzedTRIAL-SemiBold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{project.data.title} — Luis Vieira</title>
    <meta name="description" content={project.data.subtitle || project.data.title} />
    <script is:inline>
      document.documentElement.classList.add(
        document.documentElement.dataset.theme || 'dark'
      );
    </script>
  </head>
  <body>
    <div class="project-page">
      <button class="project-page__close" aria-label="Close" data-close>
        <span class="project-page__close-text">ESC /</span>
        <span class="project-page__close-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2 2L22 22" stroke="currentColor" stroke-width="1.5"></path>
            <path d="M22 2L2 22" stroke="currentColor" stroke-width="1.5"></path>
          </svg>
        </span>
      </button>
      <div class="project-page__container">
        <div class:list={["post-page", { "post-page--draft": isTemplate }]}>
          <Content components={{ PostSection, PostSectionGroup, PostHeader, PostText, Figure, ImageCarousel, Video, Divider }} />
        </div>
      </div>
    </div>

    <script is:inline>
      function goBack() {
        if (window.history.length > 1) {
          history.back();
        } else {
          window.location.href = '/';
        }
      }

      document.querySelector('[data-close]')?.addEventListener('click', goBack);

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') goBack();
      });
    </script>
    <script type="module" src="/scripts/main.js"></script>
  </body>
</html>
