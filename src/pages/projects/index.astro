---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionIndex from '../../components/CollectionIndex.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.slug !== 'project-template' && !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects — Luis Vieira" description="All projects." hideHeader={true}>
  <CollectionIndex title="Projects" basePath="projects" items={projects} />
</BaseLayout>
