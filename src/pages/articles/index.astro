---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionIndex from '../../components/CollectionIndex.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .filter((a) => a.slug !== 'article-template' && !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Articles — Luis Vieira" description="All articles." hideHeader={true}>
  <CollectionIndex title="Articles" basePath="articles" items={articles} />
</BaseLayout>
