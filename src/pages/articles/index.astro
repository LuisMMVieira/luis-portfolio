---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .filter((a) => a.slug !== 'article-template' && !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Articles — Luis Vieira" description="All articles." hideHeader={true}>

<div class="andamento">
    <header class="andamento__header">
      <h1 class="andamento__title">Articles</h1>
      <p class="andamento__desc">{articles.length} articles</p>
    </header>

    <nav class="andamento__nav">
      {articles.map((a) => (
        <a href={`/articles/${a.slug}`} class="andamento__link">
          <span class="andamento__link-label">
            {a.data.title}
          </span>
          <span class="andamento__link-path">/articles/{a.slug}</span>
        </a>
      ))}
    </nav>
  </div>

</BaseLayout>
