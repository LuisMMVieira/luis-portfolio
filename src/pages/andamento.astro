---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.slug !== 'project-template')
  .sort((a, b) => a.data.order - b.data.order);

const articles = (await getCollection('articles'))
  .filter((a) => a.slug !== 'article-template')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const reports = (await getCollection('reports'))
  .filter((r) => r.slug !== 'report-template')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Andamento — Luis Vieira" description="Private development index." hideHeader={true}>

  <a href="/" class="cp-home-btn" aria-label="Back to home">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
      <polyline points="9 22 9 12 15 12 15 22"></polyline>
    </svg>
  </a>

  <div class="andamento">
    <header class="andamento__header">
      <h1 class="andamento__title">Andamento</h1>
      <p class="andamento__desc">Private index — templates, components, and development pages.</p>
    </header>

    <section class="andamento__section">
      <h2 class="andamento__section-title">Showcases</h2>
      <nav class="andamento__nav">
        {projects.map((p) => (
          <a href={`/projects/${p.slug}`} class="andamento__link">
            <span class="andamento__link-label">
              {p.data.title}
              {p.data.draft && <span class="andamento__draft-badge">draft</span>}
            </span>
            <span class="andamento__link-path">/projects/{p.slug}</span>
          </a>
        ))}
      </nav>
    </section>

    <section class="andamento__section">
      <h2 class="andamento__section-title">Articles</h2>
      <nav class="andamento__nav">
        {articles.map((a) => (
          <a href={`/articles/${a.slug}`} class="andamento__link">
            <span class="andamento__link-label">
              {a.data.title}
              {a.data.draft && <span class="andamento__draft-badge">draft</span>}
            </span>
            <span class="andamento__link-path">/articles/{a.slug}</span>
          </a>
        ))}
      </nav>
    </section>

    {reports.length > 0 && (
      <section class="andamento__section">
        <h2 class="andamento__section-title">Reports</h2>
        <nav class="andamento__nav">
          {reports.map((r) => (
            <a href={`/reports/${r.slug}`} class="andamento__link">
              <span class="andamento__link-label">
                {r.data.title}
                {r.data.draft && <span class="andamento__draft-badge">draft</span>}
              </span>
              <span class="andamento__link-path">/reports/{r.slug}</span>
            </a>
          ))}
        </nav>
      </section>
    )}

    <section class="andamento__section">
      <h2 class="andamento__section-title">Decks</h2>
      <nav class="andamento__nav">
        <a href="/decks/spaceship-search" class="andamento__link">
          <span class="andamento__link-label">Spaceship Search — Dark</span>
          <span class="andamento__link-path">/decks/spaceship-search</span>
        </a>
        <a href="/decks/spaceship-search-light" class="andamento__link">
          <span class="andamento__link-label">Spaceship Search — Light</span>
          <span class="andamento__link-path">/decks/spaceship-search-light</span>
        </a>
        <a href="/sword-deck" class="andamento__link">
          <span class="andamento__link-label">Sword Interview — Storyboard</span>
          <span class="andamento__link-path">/sword-deck</span>
        </a>
      </nav>
    </section>

    <section class="andamento__section">
      <h2 class="andamento__section-title">Dev</h2>
      <nav class="andamento__nav">
        <a href="/" class="andamento__link">
          <span class="andamento__link-label">Homepage</span>
          <span class="andamento__link-path">/</span>
        </a>
        <a href="/components" class="andamento__link">
          <span class="andamento__link-label">Components</span>
          <span class="andamento__link-path">/components</span>
        </a>
        <a href="/projects/project-template" class="andamento__link">
          <span class="andamento__link-label">Project Template</span>
          <span class="andamento__link-path">/projects/project-template</span>
        </a>
        <a href="/articles/article-template" class="andamento__link">
          <span class="andamento__link-label">Article Template</span>
          <span class="andamento__link-path">/articles/article-template</span>
        </a>
        <a href="/reports/report-template" class="andamento__link">
          <span class="andamento__link-label">Report Template</span>
          <span class="andamento__link-path">/reports/report-template</span>
        </a>
      </nav>
    </section>
  </div>

</BaseLayout>
