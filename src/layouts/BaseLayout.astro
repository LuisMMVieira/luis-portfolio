---
import '../styles/main.scss';
import Header from '../components/Header.astro';
import AgentationToolbar from '../components/AgentationToolbar';

const {
  title = 'Luis Vieira—Digital Product Designer',
  description = 'I design purposeful digital products—clear systems with human presence.',
  hideHeader = false,
  theme = 'dark',
} = Astro.props;

const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="preload"
      href="/fonts/Dazzed-SemiBold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <slot name="head" />
    <script is:inline>
      document.documentElement.classList.add(
        document.documentElement.dataset.theme || 'dark'
      );
    </script>
  </head>
  <body>
    <div class="page">
      {!hideHeader && <Header />}
      <main class="content">
        <slot />
      </main>
    </div>

    <script is:inline>
      document.addEventListener('keydown', function(e) {
        if (e.altKey && e.code === 'KeyA') {
          e.preventDefault();
          window.location.href = '/andamento';
        }
      });
    </script>
    <script type="module" src="/scripts/main.js"></script>
    {isDev && <AgentationToolbar client:only="react" />}
  </body>
</html>
